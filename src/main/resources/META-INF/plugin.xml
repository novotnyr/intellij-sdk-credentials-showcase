<idea-plugin>
    <id>org.intellij.sdk.credentials-showcase</id>
    <name>Credentials Showcase</name>

    <vendor url="https://plugins.jetbrains.com">IntelliJ Platform SDK</vendor>

    <description><![CDATA[
        Showcase credentials storage and PasswordSafe usage
        ]]></description>

    <depends>com.intellij.modules.platform</depends>

    <extensions defaultExtensionNs="com.intellij">
        <applicationConfigurable instance="org.intellij.sdk.credentials.CredentialsConfigurable"
                                 id="org.intellij.sdk.credentials.CredentialsConfigurable"
                                 displayName="Credentials"
                                 parentId="tools"
        />
    </extensions>
</idea-plugin>
